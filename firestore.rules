rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function adminConfig() {
      return exists(/databases/$(database)/documents/config/admins)
        ? get(/databases/$(database)/documents/config/admins).data
        : null;
    }

    function isSystemGoogleAdmin() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'google.com'
        && adminConfig() != null
        && request.auth.token.email in adminConfig().systemGoogleEmails;
    }

    function isStoreGoogleAdmin() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'google.com'
        && adminConfig() != null
        && request.auth.token.email in adminConfig().storeGoogleEmails;
    }

    function isSystemAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'system-admin@sgt-vitor-edu.app'
        || isSystemGoogleAdmin()
      );
    }

    function isStoreAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'store-admin@sgt-vitor-edu.app'
        || isStoreGoogleAdmin()
      );
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /config/admins {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'google.com'
        && (
          request.auth.token.email in request.resource.data.systemGoogleEmails
          || request.auth.token.email in request.resource.data.storeGoogleEmails
        );
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /messages/{messageId} {
        allow read, write: if isOwner(userId);
      }

      match /quizResults/{resultId} {
        allow read, write: if isOwner(userId);
      }

      match /history/{entryId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if isSystemAdmin();
    }

    match /documents/{documentId} {
      allow read: if true;
      allow write: if isSystemAdmin();
    }

    match /storeProducts/{productId} {
      allow read: if true;
      allow write: if isStoreAdmin();
    }

    match /storeOrders/{orderId} {
      allow read: if isStoreAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if isStoreAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid);
      allow delete: if isStoreAdmin();
    }

    match /consultingSessions/{sessionId} {
      allow read: if isSystemAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSystemAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid);
      allow delete: if isSystemAdmin();
    }

    match /registeredUsers/{userId} {
      allow read: if isSystemAdmin();
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /analytics/visits {
      allow read: if isSystemAdmin();
      allow create, update: if true;
    }

    match /consultingRequests/{requestId} {
      allow read, create: if request.auth != null;
      allow update, delete: if isSystemAdmin();
    }

    match /analyticsEvents/{eventId} {
      allow create: if true;
      allow read, update, delete: if isSystemAdmin();
    }

    match /pdfAssets/{assetId} {
      allow read: if true;
      allow write: if isSystemAdmin();
    }
  }
}
